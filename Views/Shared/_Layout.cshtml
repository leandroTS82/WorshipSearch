<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – WorshipSearch</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600&family=Spectral:wght@400;500&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg: #181511;
            --bg-side: #1c1813;
            --bg-card: #201b14;
            --bg-input: #221c15;
            --border: #2e2820;
            --border-card: #2a2418;
            --accent: #d6915f;
            --accent-soft: rgba(214,145,95,0.14);
            --accent-line: rgba(214,145,95,0.32);
            --text: #ece3d4;
            --text-muted: #8a7e6e;
            --text-sub: #b9ad9b;
            --text-dim: #766a5b;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'Instrument Sans', system-ui, sans-serif;
            font-size: 15px;
            -webkit-font-smoothing: antialiased;
            display: flex;
            min-height: 100vh;
        }
        input::placeholder { color: var(--text-dim); }
        ::selection { background: var(--accent-soft); }

        /* Scrollbar */
        #ws-scroll::-webkit-scrollbar { width: 8px; }
        #ws-scroll::-webkit-scrollbar-thumb { background: #332c24; border-radius: 8px; border: 3px solid var(--bg); }
        #ws-scroll::-webkit-scrollbar-track { background: transparent; }

        /* Sidebar */
        #ws-side {
            width: 258px;
            flex: 0 0 258px;
            height: 100vh;
            position: sticky;
            top: 0;
            display: flex;
            flex-direction: column;
            padding: 26px 18px;
            border-right: 1px solid var(--border);
            background: var(--bg-side);
        }
        #ws-brand {
            display: flex;
            align-items: center;
            gap: 11px;
            padding: 0 6px;
            margin-bottom: 30px;
        }
        .ws-logo {
            width: 36px; height: 36px;
            border-radius: 10px;
            background: var(--accent-soft);
            border: 1px solid var(--accent-line);
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }
        .ws-brand-text { font-family: 'Spectral', serif; font-size: 18px; letter-spacing: .2px; }
        .ws-brand-text span { color: var(--accent); }

        #ws-nav { display: flex; flex-direction: column; gap: 3px; }
        .ws-nav-btn {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 12px;
            border: none; border-radius: 9px;
            background: transparent;
            color: var(--text-muted);
            font-family: inherit; font-size: 14px;
            cursor: pointer;
            text-decoration: none;
            transition: background .12s, color .12s;
            width: 100%;
            text-align: left;
        }
        .ws-nav-btn:hover { background: #241f18; color: var(--text); }
        .ws-nav-btn.active { background: #241f18; color: var(--text); }
        .ws-nav-btn svg { flex-shrink: 0; }

        #ws-stats {
            margin-top: auto;
            display: flex;
            flex-direction: column;
            gap: 14px;
            padding-top: 22px;
            border-top: 1px solid var(--border-card);
        }
        .ws-stat-row { display: flex; align-items: baseline; justify-content: space-between; }
        .ws-stat-label { color: var(--text-muted); font-size: 12.5px; }
        .ws-stat-val { font-family: 'Spectral', serif; font-size: 18px; }
        .ws-stat-bar { height: 5px; border-radius: 3px; background: var(--border-card); overflow: hidden; margin-top: 7px; }
        .ws-stat-fill { height: 100%; background: var(--accent); border-radius: 3px; }

        /* Main */
        #ws-main { flex: 1; min-width: 0; height: 100vh; overflow: hidden; }
        #ws-scroll { height: 100%; overflow-y: auto; padding: 40px 44px 80px; }

        /* Alerts */
        .ws-alert {
            padding: 12px 16px;
            border-radius: 10px;
            margin-bottom: 20px;
            font-size: 14px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }
        .ws-alert-error { background: #2a1215; border: 1px solid #5c2b2e; color: #ff8a80; }
        .ws-alert-success { background: #122016; border: 1px solid #1d4a2b; color: #69d18a; }
        .ws-alert-close { background: none; border: none; color: inherit; cursor: pointer; font-size: 18px; line-height: 1; opacity: .7; }
        .ws-alert-close:hover { opacity: 1; }

        /* Cards */
        .ws-card {
            background: var(--bg-card);
            border: 1px solid var(--border-card);
            border-radius: 14px;
            overflow: hidden;
            transition: border-color .15s;
        }
        .ws-card:hover { border-color: #3a3020; }

        /* Input */
        .ws-input {
            width: 100%;
            padding: 14px 18px;
            background: var(--bg-input);
            border: 1px solid #38301f;
            border-radius: 12px;
            color: var(--text);
            font-family: inherit;
            font-size: 15px;
            outline: none;
            transition: border-color .15s;
        }
        .ws-input:focus { border-color: var(--accent-line); }
        .ws-input-icon { padding-left: 48px; }

        /* Buttons */
        .ws-btn {
            display: inline-flex; align-items: center; justify-content: center; gap: 7px;
            padding: 10px 18px;
            border: none; border-radius: 10px;
            font-family: inherit; font-size: 14px; font-weight: 500;
            cursor: pointer;
            transition: opacity .12s, background .12s;
            text-decoration: none;
            white-space: nowrap;
        }
        .ws-btn:disabled { opacity: .45; cursor: not-allowed; }
        .ws-btn-primary { background: var(--accent); color: #1a1008; }
        .ws-btn-primary:hover { opacity: .88; }
        .ws-btn-ghost { background: rgba(255,255,255,0.06); color: var(--text-sub); border: 1px solid var(--border); }
        .ws-btn-ghost:hover { background: rgba(255,255,255,0.1); color: var(--text); }
        .ws-btn-danger { background: rgba(220,50,50,0.15); color: #ff8a80; border: 1px solid rgba(220,50,50,0.2); }
        .ws-btn-danger:hover { background: rgba(220,50,50,0.25); }
        .ws-btn-sm { padding: 6px 12px; font-size: 13px; }

        /* Chips */
        .ws-chip {
            display: inline-flex; align-items: center; gap: 5px;
            padding: 4px 10px;
            border-radius: 999px;
            font-size: 12px;
        }
        .ws-chip-theme { background: rgba(214,145,95,0.14); border: 1px solid rgba(214,145,95,0.28); color: #d6a870; }
        .ws-chip-mood  { background: rgba(100,180,120,0.12); border: 1px solid rgba(100,180,120,0.25); color: #7ec99a; }
        .ws-chip-ref   { background: rgba(140,100,200,0.12); border: 1px solid rgba(140,100,200,0.25); color: #b89ee0; }
        .ws-chip-kw    { background: rgba(80,160,220,0.12);  border: 1px solid rgba(80,160,220,0.25);  color: #80c4e8; }

        /* Badge approved */
        .ws-badge-ok  { display: inline-flex; align-items: center; gap: 4px; padding: 3px 8px; border-radius: 6px; font-size: 11.5px; background: rgba(60,180,90,0.15); border: 1px solid rgba(60,180,90,0.25); color: #69d18a; }
        .ws-badge-pend{ display: inline-flex; align-items: center; gap: 4px; padding: 3px 8px; border-radius: 6px; font-size: 11.5px; background: rgba(200,160,60,0.12); border: 1px solid rgba(200,160,60,0.22); color: #c9a857; }

        /* Section header */
        .ws-section-header {
            display: flex; align-items: center; justify-content: space-between;
            margin: 28px 0 14px;
            padding-bottom: 13px;
            border-bottom: 1px solid var(--border-card);
        }
        .ws-section-title { color: var(--text-muted); font-size: 12px; text-transform: uppercase; letter-spacing: .7px; }

        /* Page title */
        .ws-page-title { font-family: 'Spectral', serif; font-size: 28px; font-weight: 400; letter-spacing: .2px; margin-bottom: 6px; }
        .ws-page-sub { color: var(--text-muted); font-size: 14.5px; line-height: 1.55; }

        /* Grid */
        .ws-grid { display: grid; gap: 14px; }
        .ws-grid-3 { grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); }
        .ws-grid-2 { grid-template-columns: repeat(auto-fill, minmax(380px, 1fr)); }

        /* Forms */
        .ws-label { display: block; color: var(--text-muted); font-size: 12.5px; margin-bottom: 6px; letter-spacing: .3px; }
        .ws-form-group { margin-bottom: 18px; }
        textarea.ws-input { min-height: 90px; resize: vertical; }

        /* Table */
        .ws-table { width: 100%; border-collapse: collapse; }
        .ws-table th { font-size: 12px; text-transform: uppercase; letter-spacing: .6px; color: var(--text-muted); padding: 10px 14px; border-bottom: 1px solid var(--border-card); text-align: left; font-weight: 500; }
        .ws-table td { padding: 12px 14px; border-bottom: 1px solid var(--border-card); font-size: 14px; vertical-align: middle; }
        .ws-table tr:last-child td { border-bottom: none; }
        .ws-table tr:hover td { background: rgba(255,255,255,0.02); }

        /* Divider */
        .ws-divider { height: 1px; background: var(--border-card); margin: 24px 0; }

        /* Fade animation */
        @keyframes wsfade { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }
        .ws-fade { animation: wsfade .2s ease; }

        /* Spinner */
        .ws-spinner { display: inline-block; width: 18px; height: 18px; border: 2px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin .6s linear infinite; }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* Responsive */
        @media (max-width: 860px) {
            body { flex-direction: column; }
            #ws-side { width: 100%; height: auto; position: static; flex-direction: row; align-items: center; gap: 8px; overflow-x: auto; padding: 12px 14px; border-right: none; border-bottom: 1px solid var(--border); }
            #ws-nav { flex-direction: row; flex: 1; gap: 4px; }
            .ws-nav-btn { white-space: nowrap; width: auto; }
            #ws-stats { display: none; }
            #ws-brand { margin-bottom: 0; margin-right: 6px; }
            #ws-main { height: auto; }
            #ws-scroll { height: auto; padding: 24px 16px 60px; }
            .ws-grid-3 { grid-template-columns: 1fr; }
            .ws-grid-2 { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

<aside id="ws-side">
    <div id="ws-brand">
        <div class="ws-logo">
            <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 18V5l11-2v13"></path>
                <circle cx="6" cy="18" r="3"></circle>
                <circle cx="20" cy="16" r="3"></circle>
            </svg>
        </div>
        <div class="ws-brand-text">Worship<span> Search</span></div>
    </div>

    <nav id="ws-nav">
        <a href="@Url.Action("Index","Home")" class="ws-nav-btn @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.5" y2="16.5"/></svg>
            Pesquisar
        </a>
        <a href="@Url.Action("Index","MusicSearch")" class="ws-nav-btn @(ViewContext.RouteData.Values["controller"]?.ToString() == "MusicSearch" ? "active" : "")">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Indexar
        </a>
        <a href="@Url.Action("Index","MusicLibrary")" class="ws-nav-btn @(ViewContext.RouteData.Values["controller"]?.ToString() == "MusicLibrary" ? "active" : "")">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
            Biblioteca
        </a>
    </nav>

    <div id="ws-stats">
        <div>
            <div class="ws-stat-row">
                <span class="ws-stat-label">Louvores indexados</span>
                <span class="ws-stat-val" id="stat-total">–</span>
            </div>
        </div>
        <div>
            <div class="ws-stat-row" style="margin-bottom:7px">
                <span class="ws-stat-label">Aprovados</span>
                <span style="font-size:13px;color:var(--text-sub)" id="stat-approved-label">–</span>
            </div>
            <div class="ws-stat-bar"><div class="ws-stat-fill" id="stat-bar" style="width:0%"></div></div>
        </div>
        <div style="display:flex;align-items:center;gap:8px;color:var(--text-muted);font-size:12.5px">
            <span style="width:7px;height:7px;border-radius:50%;background:#c9a857;display:inline-block"></span>
            <span id="stat-pending-label">– aguardando revisão</span>
        </div>
    </div>
</aside>

<main id="ws-main">
    <div id="ws-scroll">
        @if (TempData["Error"] != null)
        {
            <div class="ws-alert ws-alert-error">
                <span>@TempData["Error"]</span>
                <button class="ws-alert-close" onclick="this.parentElement.remove()">×</button>
            </div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="ws-alert ws-alert-success">
                <span>@TempData["Success"]</span>
                <button class="ws-alert-close" onclick="this.parentElement.remove()">×</button>
            </div>
        }
        @RenderBody()
    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script>
    // Load sidebar stats
    fetch('/MusicLibrary/Stats').then(r => r.json()).then(d => {
        document.getElementById('stat-total').textContent = d.total;
        document.getElementById('stat-approved-label').textContent = d.approved + ' de ' + d.total;
        document.getElementById('stat-bar').style.width = (d.total > 0 ? Math.round(d.approved / d.total * 100) : 0) + '%';
        document.getElementById('stat-pending-label').textContent = (d.total - d.approved) + ' aguardando revisão';
    }).catch(() => {});
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
