<!DOCTYPE html>
<html lang="pt-BR" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WorshipSearch</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body { min-height: 100vh; }
        #sidebar {
            width: 240px;
            min-height: 100vh;
            background: #1a1d21;
            border-right: 1px solid #2d3035;
            flex-shrink: 0;
        }
        #sidebar .brand {
            font-size: 1.1rem;
            font-weight: 700;
            letter-spacing: 0.02em;
            color: #e9ecef;
        }
        #sidebar .nav-link {
            color: #adb5bd;
            border-radius: 6px;
            margin-bottom: 2px;
            font-size: 0.9rem;
        }
        #sidebar .nav-link:hover, #sidebar .nav-link.active {
            color: #fff;
            background: rgba(255,255,255,0.08);
        }
        #sidebar .nav-link i { width: 1.4rem; }
        #main-content { flex: 1; min-width: 0; overflow-y: auto; }
        .chip {
            display: inline-block;
            padding: 2px 10px;
            border-radius: 20px;
            font-size: 0.75rem;
            margin: 2px;
            background: rgba(255,255,255,0.1);
            color: #dee2e6;
        }
        .chip-theme { background: rgba(13,110,253,0.25); color: #6ea8fe; }
        .chip-mood { background: rgba(25,135,84,0.25); color: #75b798; }
        .chip-ref { background: rgba(102,16,242,0.25); color: #c29ffa; }
        .chip-keyword { background: rgba(255,193,7,0.2); color: #ffda6a; }
        .song-card { transition: border-color .15s; }
        .song-card:hover { border-color: rgba(255,255,255,0.3) !important; }
        .lyrics-box { white-space: pre-wrap; font-family: inherit; font-size: 0.9rem; }
        textarea.form-control { min-height: 100px; }
    </style>
</head>
<body class="d-flex">
    <nav id="sidebar" class="p-3 d-flex flex-column">
        <div class="brand mb-4 px-2">
            <i class="bi bi-music-note-beamed me-2 text-primary"></i>WorshipSearch
        </div>
        <ul class="nav flex-column gap-1">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                   href="@Url.Action("Index","Home")">
                    <i class="bi bi-search"></i> Pesquisar Biblioteca
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "MusicSearch" ? "active" : "")"
                   href="@Url.Action("Index","MusicSearch")">
                    <i class="bi bi-cloud-download"></i> Indexar Música
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "MusicLibrary" ? "active" : "")"
                   href="@Url.Action("Index","MusicLibrary")">
                    <i class="bi bi-collection"></i> Biblioteca
                </a>
            </li>
        </ul>
    </nav>
    <div id="main-content" class="p-4">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
