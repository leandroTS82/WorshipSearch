@model WorshipSearch.Models.MusicDocument
@{
    ViewData["Title"] = "Preview - " + Model.Title;
    var alreadyExists = (bool)(ViewBag.AlreadyExists ?? false);
}

<div class="mb-3 d-flex align-items-center gap-3">
    <a href="@Url.Action("Index","MusicSearch")" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Voltar
    </a>
    <h5 class="mb-0 fw-bold">Preview: @Model.Title</h5>
    @if (alreadyExists)
    {
        <span class="badge bg-warning text-dark"><i class="bi bi-exclamation-triangle"></i> Já indexada</span>
    }
</div>

<div class="row g-4">
    <div class="col-12 col-lg-5">
        <div class="card bg-dark border-secondary">
            <div class="card-header border-secondary fw-semibold">Informações</div>
            <div class="card-body">
                @if (!string.IsNullOrWhiteSpace(Model.Metadata.Image))
                {
                    <img src="@Model.Metadata.Image" class="rounded mb-3" style="max-width:100%;max-height:160px;object-fit:cover" alt="" />
                }
                <dl class="row small mb-0">
                    <dt class="col-4 text-muted">Título</dt><dd class="col-8">@Model.Title</dd>
                    <dt class="col-4 text-muted">Artista</dt><dd class="col-8">@Model.Artist</dd>
                    <dt class="col-4 text-muted">ID</dt><dd class="col-8 text-muted font-monospace small">@Model.Id</dd>
                    <dt class="col-4 text-muted">URL</dt>
                    <dd class="col-8"><a href="@Model.Metadata.CanonicalUrl" target="_blank" class="text-truncate d-block small">@Model.Metadata.CanonicalUrl</a></dd>
                </dl>
            </div>
        </div>

        <div class="card bg-dark border-secondary mt-3">
            <div class="card-header border-secondary fw-semibold">Letra</div>
            <div class="card-body p-0">
                <pre class="lyrics-box text-muted p-3 mb-0" style="max-height:350px;overflow-y:auto">@Model.Lyrics</pre>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-7">
        <div class="card bg-dark border-secondary">
            <div class="card-header border-secondary d-flex justify-content-between align-items-center">
                <span class="fw-semibold">Enriquecimento com IA</span>
                <div class="d-flex gap-2">
                    <button id="enrichBtn" class="btn btn-sm btn-primary">
                        <i class="bi bi-stars"></i> Enriquecer com IA
                    </button>
                    <button id="saveBtn" class="btn btn-sm btn-success" disabled>
                        <i class="bi bi-save"></i> Salvar
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div id="enrichStatus" class="text-muted small mb-3 d-none">
                    <div class="spinner-border spinner-border-sm me-2"></div> Enriquecendo com Groq LLM...
                </div>

                <div id="enrichResult" class="d-none">
                    <div class="mb-3">
                        <label class="form-label small text-muted">Resumo</label>
                        <div id="summary" class="border border-secondary rounded p-2 small"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted">Temas</label>
                        <div id="themes"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted">Moods</label>
                        <div id="moods"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted">Referências Bíblicas</label>
                        <div id="bibrefs"></div>
                    </div>
                    <div class="row g-2 mb-2">
                        <div class="col">
                            <label class="form-label small text-muted">Estilo</label>
                            <div id="wstyle" class="text-info small"></div>
                        </div>
                        <div class="col">
                            <label class="form-label small text-muted">Energia</label>
                            <div id="elevel" class="text-warning small"></div>
                        </div>
                        <div class="col">
                            <label class="form-label small text-muted">Ocasião</label>
                            <div id="occasion" class="text-success small"></div>
                        </div>
                    </div>
                </div>

                <div id="noEnrich" class="text-muted small">
                    Clique em "Enriquecer com IA" para analisar a música com Groq LLM.
                </div>
            </div>
        </div>

        <div class="mt-3 d-flex gap-2">
            <a href="#" id="editLink" class="btn btn-outline-light d-none">
                <i class="bi bi-pencil"></i> Editar na Biblioteca
            </a>
        </div>
    </div>
</div>

@section Scripts {
<script>
var docData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model, new System.Text.Json.JsonSerializerOptions {
    Encoder = System.Text.Encodings.Web.JavaScriptEncoder.UnsafeRelaxedJsonEscaping
}));

function chips(arr, cls) {
    if (!arr || !arr.length) return '<span class="text-muted small">—</span>';
    return arr.map(t => `<span class="chip ${cls}">${t}</span>`).join('');
}

$('#enrichBtn').click(function(){
    $(this).prop('disabled', true);
    $('#enrichStatus').removeClass('d-none');
    $('#enrichResult').addClass('d-none');
    $('#noEnrich').addClass('d-none');

    $.ajax({
        url: '@Url.Action("Enrich","MusicIndex")',
        method: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(docData),
        success: function(enriched) {
            docData = enriched;
            $('#enrichStatus').addClass('d-none');
            $('#enrichResult').removeClass('d-none');
            $('#summary').text(enriched.summary || '—');
            var s = enriched.search || {};
            $('#themes').html(chips(s.themes, 'chip-theme'));
            $('#moods').html(chips(s.moods, 'chip-mood'));
            $('#bibrefs').html(chips(s.biblical_references, 'chip-ref'));
            $('#wstyle').text(s.worship_style || '—');
            $('#elevel').text(s.energy_level || '—');
            $('#occasion').text(s.occasion || '—');
            $('#saveBtn').prop('disabled', false);
            $('#enrichBtn').prop('disabled', false);
        },
        error: function(xhr) {
            $('#enrichStatus').addClass('d-none');
            $('#noEnrich').removeClass('d-none').html('<span class="text-danger">Erro: ' + (xhr.responseJSON?.error || xhr.statusText) + '</span>');
            $('#enrichBtn').prop('disabled', false);
            $('#saveBtn').prop('disabled', false); // allow save without enrichment
        }
    });
});

$('#saveBtn').click(function(){
    $(this).prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Salvando...');
    $.ajax({
        url: '@Url.Action("Save","MusicIndex")',
        method: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(docData),
        success: function(r) {
            $('#saveBtn').html('<i class="bi bi-check-circle"></i> Salvo!').removeClass('btn-success').addClass('btn-outline-success');
            var editUrl = '@Url.Action("Edit","MusicEditor")?fileName=' + encodeURIComponent(r.fileName);
            $('#editLink').attr('href', editUrl).removeClass('d-none');
        },
        error: function(xhr) {
            alert('Erro ao salvar: ' + (xhr.responseJSON?.error || xhr.statusText));
            $('#saveBtn').prop('disabled', false).html('<i class="bi bi-save"></i> Salvar');
        }
    });
});

// Allow save before enrichment
$('#saveBtn').prop('disabled', false);
</script>
}
