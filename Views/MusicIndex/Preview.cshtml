@model WorshipSearch.Models.MusicDocument
@{
    ViewData["Title"] = "Preview – " + Model.Title;
    var alreadyExists = (bool)(ViewBag.AlreadyExists ?? false);
}

<div style="max-width:1020px;margin:0 auto" class="ws-fade">

    <div style="display:flex;align-items:center;gap:14px;margin-bottom:28px">
        <a href="@Url.Action("Index","MusicSearch")" class="ws-btn ws-btn-ghost ws-btn-sm">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 5 5 12 12 19"/></svg>
            Voltar
        </a>
        <div>
            <div style="font-family:'Spectral',serif;font-size:22px">@Model.Title</div>
            <div style="color:var(--text-muted);font-size:13.5px;margin-top:2px">@Model.Artist</div>
        </div>
        @if (alreadyExists)
        {
            <span class="ws-badge-pend" style="margin-left:4px">já indexada</span>
        }
    </div>

    <div style="display:grid;grid-template-columns:1fr 1.4fr;gap:20px;align-items:start">

        {{-- Left: meta + letra --}}
        <div>
            <div class="ws-card" style="padding:20px;margin-bottom:14px">
                @if (!string.IsNullOrWhiteSpace(Model.Metadata?.Image))
                {
                    <img src="@Model.Metadata.Image" style="width:100%;border-radius:10px;max-height:180px;object-fit:cover;margin-bottom:16px;border:1px solid var(--border)" alt="" />
                }
                <div style="display:grid;grid-template-columns:auto 1fr;gap:6px 14px;font-size:13.5px">
                    <span style="color:var(--text-muted)">ID</span><span style="font-family:monospace;font-size:12px;color:var(--text-sub)">@Model.Id</span>
                    <span style="color:var(--text-muted)">Fonte</span>
                    <a href="@Model.Metadata?.CanonicalUrl" target="_blank" rel="noopener" style="color:var(--accent);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">letras.mus.br</a>
                </div>
            </div>

            <div class="ws-card">
                <div style="padding:14px 18px;border-bottom:1px solid var(--border-card);font-size:13px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px">Letra</div>
                <pre style="padding:16px 18px;margin:0;white-space:pre-wrap;font-family:inherit;font-size:13.5px;color:var(--text-sub);line-height:1.7;max-height:420px;overflow-y:auto">@Model.Lyrics</pre>
            </div>
        </div>

        {{-- Right: enrichment --}}
        <div class="ws-card">
            <div style="padding:16px 20px;border-bottom:1px solid var(--border-card);display:flex;align-items:center;justify-content:space-between;gap:12px">
                <span style="font-weight:500">Enriquecimento com IA</span>
                <div style="display:flex;gap:8px">
                    <button id="enrichBtn" class="ws-btn ws-btn-ghost ws-btn-sm">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M12 2l2 7h7l-5.5 4 2 7L12 16l-5.5 4 2-7L3 9h7z"/></svg>
                        Enriquecer com IA
                    </button>
                    <button id="saveBtn" class="ws-btn ws-btn-primary ws-btn-sm">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                        Salvar
                    </button>
                </div>
            </div>

            <div style="padding:20px">
                <div id="enrichStatus" style="display:none;padding:24px 0;text-align:center;color:var(--text-muted)">
                    <div class="ws-spinner" style="margin:0 auto 12px"></div>
                    Enriquecendo com Groq LLM…
                </div>

                <div id="noEnrich" style="color:var(--text-muted);font-size:14px;text-align:center;padding:32px 0">
                    Clique em <strong style="color:var(--text)">Enriquecer com IA</strong> para analisar a música.
                    <br><span style="font-size:12.5px;margin-top:6px;display:block">Você também pode salvar sem enriquecer.</span>
                </div>

                <div id="enrichResult" style="display:none">
                    <div class="ws-form-group">
                        <div class="ws-label">Resumo</div>
                        <div id="summary" style="font-size:14px;color:var(--text-sub);line-height:1.6;background:var(--bg-input);border:1px solid var(--border-card);border-radius:10px;padding:12px 14px"></div>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px">
                        <div>
                            <div class="ws-label">Temas</div>
                            <div id="themes" style="display:flex;flex-wrap:wrap;gap:5px"></div>
                        </div>
                        <div>
                            <div class="ws-label">Emoções</div>
                            <div id="moods" style="display:flex;flex-wrap:wrap;gap:5px"></div>
                        </div>
                    </div>
                    <div class="ws-form-group">
                        <div class="ws-label">Referências Bíblicas</div>
                        <div id="bibrefs" style="display:flex;flex-wrap:wrap;gap:5px"></div>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px">
                        <div>
                            <div class="ws-label">Estilo</div>
                            <div id="wstyle" style="font-size:13.5px;color:var(--text-sub)"></div>
                        </div>
                        <div>
                            <div class="ws-label">Energia</div>
                            <div id="elevel" style="font-size:13.5px;color:var(--accent)"></div>
                        </div>
                        <div>
                            <div class="ws-label">Ocasião</div>
                            <div id="occasion" style="font-size:13.5px;color:var(--text-sub)"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="editLinkArea" style="display:none;padding:14px 20px;border-top:1px solid var(--border-card)">
                <a href="#" id="editLink" class="ws-btn ws-btn-ghost ws-btn-sm">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    Editar na Biblioteca
                </a>
            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
var docData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model, new System.Text.Json.JsonSerializerOptions {
    Encoder = System.Text.Encodings.Web.JavaScriptEncoder.UnsafeRelaxedJsonEscaping,
    PropertyNamingPolicy = null
}));

function chips(arr, cls) {
    if (!arr || !arr.length) return '<span style="color:var(--text-dim);font-size:13px">—</span>';
    return arr.map(function(t){ return '<span class="ws-chip ' + cls + '">' + escHtml(t) + '</span>'; }).join('');
}
function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

$('#enrichBtn').click(function(){
    $(this).prop('disabled', true);
    $('#enrichStatus').show();
    $('#enrichResult').hide();
    $('#noEnrich').hide();

    $.ajax({
        url: '@Url.Action("Enrich","MusicIndex")',
        method: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(docData),
        success: function(enriched) {
            docData = enriched;
            $('#enrichStatus').hide();
            $('#enrichResult').show();
            $('#summary').text(enriched.summary || '—');
            var s = enriched.search || {};
            $('#themes').html(chips(s.themes, 'ws-chip-theme'));
            $('#moods').html(chips(s.moods, 'ws-chip-mood'));
            $('#bibrefs').html(chips(s.biblical_references, 'ws-chip-ref'));
            $('#wstyle').text(s.worship_style || '—');
            $('#elevel').text(s.energy_level || '—');
            $('#occasion').text(s.occasion || '—');
            $('#enrichBtn').prop('disabled', false).html('<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M12 2l2 7h7l-5.5 4 2 7L12 16l-5.5 4 2-7L3 9h7z"/></svg> Re-enriquecer');
        },
        error: function(xhr) {
            $('#enrichStatus').hide();
            $('#noEnrich').show().html('<span style="color:#ff8a80">Erro: ' + escHtml((xhr.responseJSON && xhr.responseJSON.error) || xhr.statusText) + '</span>');
            $('#enrichBtn').prop('disabled', false);
        }
    });
});

$('#saveBtn').click(function(){
    var btn = $(this);
    btn.prop('disabled', true).html('<div class="ws-spinner" style="width:14px;height:14px;border-width:2px;display:inline-block"></div> Salvando…');
    $.ajax({
        url: '@Url.Action("Save","MusicIndex")',
        method: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(docData),
        success: function(r) {
            btn.html('✓ Salvo!');
            var editUrl = '@Url.Action("Edit","MusicEditor")?fileName=' + encodeURIComponent(r.fileName);
            $('#editLink').attr('href', editUrl);
            $('#editLinkArea').show();
        },
        error: function(xhr) {
            alert('Erro ao salvar: ' + ((xhr.responseJSON && xhr.responseJSON.error) || xhr.statusText));
            btn.prop('disabled', false).html('Salvar');
        }
    });
});
</script>
}
