@{
    ViewData["Title"] = "Indexar Música";
}

<div style="max-width:860px;margin:0 auto" class="ws-fade">

    <div style="margin-bottom:24px">
        <div class="ws-page-title">Indexar música</div>
        <div class="ws-page-sub">Busque no letras.mus.br, selecione e gere o JSON enriquecido com IA.</div>
    </div>

    <div style="position:relative;margin-bottom:20px">
        <svg style="position:absolute;left:17px;top:50%;transform:translateY(-50%);pointer-events:none" width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.7" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.5" y2="16.5"/></svg>
        <input type="text" id="search-input"
               class="ws-input ws-input-icon"
               style="font-size:16px;padding:17px 18px 17px 50px;border-radius:14px"
               placeholder="Nome da música ou artista…"
               autocomplete="off" autofocus />
    </div>

    <div id="results-area"></div>

</div>

@section Scripts {
<script>
    var timer = null;
    var lastQ = '';

    $('#search-input').on('input', function() {
        var q = $(this).val().trim();
        clearTimeout(timer);
        if (q.length < 2) { $('#results-area').html(''); return; }
        if (q === lastQ) return;
        timer = setTimeout(function() { doSearch(q); }, 350);
    });

    $('#search-input').on('keydown', function(e) {
        if (e.key === 'Enter') { clearTimeout(timer); doSearch($(this).val().trim()); }
    });

    function doSearch(q) {
        if (!q) return;
        lastQ = q;
        $('#results-area').html('<div style="padding:40px 0;text-align:center"><div class="ws-spinner"></div></div>');
        $.getJSON('@Url.Action("SearchApi","MusicSearch")', { q: q })
            .done(renderResults)
            .fail(function() {
                $('#results-area').html('<div style="padding:40px 0;text-align:center;color:var(--text-muted)">Erro ao buscar. Tente novamente.</div>');
            });
    }

    function renderResults(data) {
        if (!data || data.length === 0) {
            $('#results-area').html('<div style="padding:40px 0;text-align:center;color:var(--text-muted)">Nenhuma música encontrada.</div>');
            return;
        }

        var musics = data.filter(function(d) { return d.Title && d.ArtistSlug; });
        if (musics.length === 0) {
            $('#results-area').html('<div style="padding:40px 0;text-align:center;color:var(--text-muted)">Nenhuma música encontrada.</div>');
            return;
        }

        var html = '<div style="color:var(--text-muted);font-size:12.5px;text-transform:uppercase;letter-spacing:.6px;margin-bottom:14px">' + musics.length + ' resultado(s)</div>';
        html += '<div class="ws-grid ws-grid-2">';

        musics.slice(0, 20).forEach(function(m) {
            var musicUrl = m.Url || ('https://www.letras.mus.br/' + m.ArtistSlug + '/' + m.SongSlug + '/');
            var previewUrl = '@Url.Action("Preview","MusicIndex")' + '?url=' + encodeURIComponent(musicUrl);
            var img = m.Image
                ? '<img src="' + escHtml(m.Image) + '" width="44" height="44" style="border-radius:8px;object-fit:cover;flex-shrink:0;border:1px solid var(--border)" alt="" />'
                : '<div style="width:44px;height:44px;border-radius:8px;background:var(--accent-soft);border:1px solid var(--accent-line);display:flex;align-items:center;justify-content:center;flex-shrink:0"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round"><path d="M9 18V5l11-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="20" cy="16" r="3"/></svg></div>';

            html += '<div class="ws-card" style="padding:16px;display:flex;align-items:center;gap:13px">';
            html += img;
            html += '<div style="flex:1;min-width:0">';
            html += '<div style="font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + escHtml(m.Title) + '</div>';
            html += '<div style="color:var(--text-muted);font-size:13px;margin-top:2px">' + escHtml(m.Artist || '');
            if (m.Genre) html += ' · <span style="color:var(--text-dim)">' + escHtml(m.Genre) + '</span>';
            html += '</div></div>';
            html += '<a href="' + previewUrl + '" class="ws-btn ws-btn-primary ws-btn-sm" style="flex-shrink:0">Indexar</a>';
            html += '</div>';
        });

        html += '</div>';
        $('#results-area').html(html);
    }

    function escHtml(s) {
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
</script>
}
