@model List<WorshipSearch.Models.SearchResult>
@{
    ViewData["Title"] = "Resultados";
    var query = ViewBag.Query as string ?? "";
}

<div class="mb-4">
    <a href="@Url.Action("Index","MusicSearch")" class="btn btn-sm btn-outline-secondary mb-3">
        <i class="bi bi-arrow-left"></i> Nova busca
    </a>
    <h5 class="fw-bold">Resultados para "@query"</h5>
    <p class="text-muted small">@Model.Count resultado(s)</p>
</div>

<div class="row g-3">
    @foreach (var r in Model)
    {
        <div class="col-12 col-md-6 col-xl-4">
            <div class="card bg-dark border-secondary song-card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    @if (!string.IsNullOrWhiteSpace(r.Image))
                    {
                        <img src="@r.Image" class="rounded" width="48" height="48" style="object-fit:cover;flex-shrink:0" alt="" />
                    }
                    <div class="flex-grow-1 min-w-0">
                        <div class="fw-semibold text-truncate">@r.Title</div>
                        <div class="text-muted small text-truncate">@r.Artist</div>
                        @if (!string.IsNullOrWhiteSpace(r.Genre))
                        {
                            <span class="chip">@r.Genre</span>
                        }
                    </div>
                </div>
                <div class="card-footer border-secondary">
                    <a href="@Url.Action("Preview","MusicIndex")?url=@Uri.EscapeDataString(r.Url)"
                       class="btn btn-sm btn-primary w-100">
                        <i class="bi bi-eye"></i> Visualizar &amp; Indexar
                    </a>
                </div>
            </div>
        </div>
    }
</div>
