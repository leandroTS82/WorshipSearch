@model List<WorshipSearch.Models.LibrarySearchResult>
@{
    ViewData["Title"] = "Pesquisar Biblioteca";
    var query = ViewBag.Query as string ?? "";
    var approvedOnly = (bool)(ViewBag.ApprovedOnly ?? false);
}

<div class="mb-4">
    <h4 class="fw-bold mb-1"><i class="bi bi-search text-primary me-2"></i>Pesquisar Biblioteca</h4>
    <p class="text-muted small mb-3">Busque músicas salvas por tema, referência bíblica, mood ou letra.</p>
    <form method="get" action="@Url.Action("Index","Home")">
        <div class="input-group input-group-lg mb-2">
            <input type="text" name="q" value="@query" class="form-control"
                   placeholder="Ex: gratidão, João 3:16, adoração, comunhão..." autofocus />
            <button class="btn btn-primary px-4" type="submit">
                <i class="bi bi-search"></i> Buscar
            </button>
        </div>
        <div class="form-check form-switch d-inline-flex align-items-center gap-2">
            <input class="form-check-input" type="checkbox" name="approvedOnly" value="true" id="approvedOnly"
                   @(approvedOnly ? "checked" : "") onchange="this.form.submit()" />
            <label class="form-check-label text-muted small" for="approvedOnly">Apenas aprovadas</label>
        </div>
    </form>
</div>

@if (!string.IsNullOrWhiteSpace(query) || Model.Count > 0)
{
    <p class="text-muted small mb-3">@Model.Count resultado(s)@(string.IsNullOrWhiteSpace(query) ? "" : $" para \"{query}\"")</p>
}

<div class="row g-3">
    @foreach (var item in Model)
    {
        var doc = item.Document;
        <div class="col-12 col-md-6 col-xl-4">
            <div class="card bg-dark border-secondary song-card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-start gap-3 mb-2">
                        @if (!string.IsNullOrWhiteSpace(doc.Metadata.Image))
                        {
                            <img src="@doc.Metadata.Image" class="rounded" width="48" height="48" style="object-fit:cover;flex-shrink:0" alt="" />
                        }
                        <div class="flex-grow-1 min-w-0">
                            <div class="fw-semibold text-truncate">@doc.Title</div>
                            <div class="text-muted small text-truncate">@doc.Artist</div>
                        </div>
                        @if (doc.Approved)
                        {
                            <span class="badge bg-success"><i class="bi bi-check-circle"></i></span>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(doc.Summary))
                    {
                        <p class="small text-muted mb-2" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">@doc.Summary</p>
                    }

                    <div class="mb-1">
                        @foreach (var t in doc.Search.Themes.Take(3))
                        {
                            <span class="chip chip-theme">@t</span>
                        }
                        @foreach (var m in doc.Search.Moods.Take(2))
                        {
                            <span class="chip chip-mood">@m</span>
                        }
                        @foreach (var r in doc.Search.BiblicalReferences.Take(2))
                        {
                            <span class="chip chip-ref">@r</span>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(doc.Search.EnergyLevel))
                    {
                        <div class="text-muted" style="font-size:.72rem">
                            Energia: @doc.Search.EnergyLevel
                            @if (!string.IsNullOrWhiteSpace(doc.Search.WorshipStyle))
                            {
                                <span class="ms-2">• @doc.Search.WorshipStyle</span>
                            }
                        </div>
                    }
                </div>
                <div class="card-footer border-secondary d-flex gap-2">
                    <a href="@Url.Action("Edit","MusicEditor", new { fileName = item.FileName })" class="btn btn-sm btn-outline-light flex-grow-1">
                        <i class="bi bi-pencil"></i> Editar
                    </a>
                    @if (!string.IsNullOrWhiteSpace(doc.Metadata.CanonicalUrl))
                    {
                        <a href="@doc.Metadata.CanonicalUrl" target="_blank" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-box-arrow-up-right"></i>
                        </a>
                    }
                </div>
            </div>
        </div>
    }
</div>

@if (Model.Count == 0 && !string.IsNullOrWhiteSpace(query))
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-search fs-1 d-block mb-3"></i>
        <p>Nenhuma música encontrada. Tente <a href="@Url.Action("Index","MusicSearch")">indexar uma música nova</a>.</p>
    </div>
}
else if (Model.Count == 0)
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-collection fs-1 d-block mb-3"></i>
        <p>Biblioteca vazia. <a href="@Url.Action("Index","MusicSearch")">Indexar músicas</a> para começar.</p>
    </div>
}
