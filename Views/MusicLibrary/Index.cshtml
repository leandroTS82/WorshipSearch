@model List<WorshipSearch.Models.LibrarySearchResult>
@{
    ViewData["Title"] = "Biblioteca";
    var query = ViewBag.Query as string ?? "";
    var approvedOnly = (bool)(ViewBag.ApprovedOnly ?? false);
}

<div style="max-width:1100px;margin:0 auto" class="ws-fade">

    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:14px">
        <div>
            <div class="ws-page-title">Biblioteca</div>
            <div class="ws-page-sub">@Model.Count música(s) indexada(s)</div>
        </div>
        <a href="@Url.Action("Index","MusicSearch")" class="ws-btn ws-btn-primary ws-btn-sm">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Indexar nova
        </a>
    </div>

    <form method="get" action="@Url.Action("Index","MusicLibrary")" style="display:flex;align-items:center;gap:10px;margin-bottom:20px;flex-wrap:wrap">
        <div style="position:relative;flex:1;min-width:220px">
            <svg style="position:absolute;left:13px;top:50%;transform:translateY(-50%);pointer-events:none" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.8" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.5" y2="16.5"/></svg>
            <input type="text" name="q" value="@query" class="ws-input" style="padding-left:38px;padding-top:10px;padding-bottom:10px" placeholder="Filtrar por título, artista, tema…" />
        </div>
        <button class="ws-btn ws-btn-ghost ws-btn-sm" type="submit">Filtrar</button>
        @if (!string.IsNullOrWhiteSpace(query))
        {
            <a href="@Url.Action("Index","MusicLibrary")" class="ws-btn ws-btn-ghost ws-btn-sm">Limpar</a>
        }
        <label style="display:flex;align-items:center;gap:7px;font-size:13.5px;color:var(--text-muted);cursor:pointer;white-space:nowrap">
            <input type="checkbox" name="approvedOnly" value="true" @(approvedOnly ? "checked" : "") onchange="this.form.submit()" style="accent-color:var(--accent)" />
            Apenas aprovadas
        </label>
    </form>

    @if (Model.Count == 0)
    {
        <div style="text-align:center;padding:64px 0;color:var(--text-muted)">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" style="margin-bottom:16px;opacity:.5"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
            <div style="font-size:15px;margin-bottom:8px">Nenhuma música encontrada</div>
            <div style="font-size:13.5px"><a href="@Url.Action("Index","MusicSearch")" style="color:var(--accent)">Indexe músicas</a> para começar.</div>
        </div>
    }
    else
    {
        <div class="ws-card" style="overflow:hidden">
            <table class="ws-table">
                <thead>
                    <tr>
                        <th style="width:52px"></th>
                        <th>Título</th>
                        <th>Artista</th>
                        <th>Temas</th>
                        <th>Emoções</th>
                        <th style="width:100px">Status</th>
                        <th style="width:80px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var doc = item.Document;
                        <tr>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(doc.Metadata?.Image))
                                {
                                    <img src="@doc.Metadata.Image" width="36" height="36" style="border-radius:8px;object-fit:cover;border:1px solid var(--border)" alt="" />
                                }
                                else
                                {
                                    <div style="width:36px;height:36px;border-radius:8px;background:var(--accent-soft);border:1px solid var(--accent-line);display:flex;align-items:center;justify-content:center">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round"><path d="M9 18V5l11-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="20" cy="16" r="3"/></svg>
                                    </div>
                                }
                            </td>
                            <td style="font-weight:500">@doc.Title</td>
                            <td style="color:var(--text-muted);font-size:13px">@doc.Artist</td>
                            <td>
                                <div style="display:flex;flex-wrap:wrap;gap:4px">
                                    @foreach (var t in (doc.Search?.Themes ?? new()).Take(2))
                                    {
                                        <span class="ws-chip ws-chip-theme">@t</span>
                                    }
                                </div>
                            </td>
                            <td>
                                <div style="display:flex;flex-wrap:wrap;gap:4px">
                                    @foreach (var m in (doc.Search?.Moods ?? new()).Take(2))
                                    {
                                        <span class="ws-chip ws-chip-mood">@m</span>
                                    }
                                </div>
                            </td>
                            <td>
                                <button class="ws-btn ws-btn-sm toggle-approved @(doc.Approved ? "" : "ws-btn-ghost")"
                                        style="@(doc.Approved ? "background:rgba(60,180,90,0.15);border:1px solid rgba(60,180,90,0.25);color:#69d18a" : "")"
                                        data-filename="@item.FileName">
                                    @(doc.Approved ? "✓ Aprovada" : "Revisar")
                                </button>
                            </td>
                            <td>
                                <div style="display:flex;gap:6px;justify-content:flex-end">
                                    <a href="@Url.Action("Edit","MusicEditor", new { fileName = item.FileName })" class="ws-btn ws-btn-ghost ws-btn-sm" title="Editar">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    </a>
                                    <button class="ws-btn ws-btn-danger ws-btn-sm delete-btn" data-filename="@item.FileName" title="Excluir">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
<script>
$('.toggle-approved').click(function(){
    var btn = $(this);
    var fileName = btn.data('filename');
    $.post('@Url.Action("ToggleApproved","MusicLibrary")', { fileName: fileName }, function(r){
        if (r.approved) {
            btn.attr('style', 'background:rgba(60,180,90,0.15);border:1px solid rgba(60,180,90,0.25);color:#69d18a').removeClass('ws-btn-ghost').text('✓ Aprovada');
        } else {
            btn.attr('style', '').addClass('ws-btn-ghost').text('Revisar');
        }
    });
});

$('.delete-btn').click(function(){
    if (!confirm('Excluir esta música da biblioteca?')) return;
    var btn = $(this);
    var fileName = btn.data('filename');
    $.ajax({
        url: '@Url.Action("Delete","MusicLibrary")?fileName=' + encodeURIComponent(fileName),
        method: 'DELETE',
        success: function(){ btn.closest('tr').fadeOut(250, function(){ $(this).remove(); }); },
        error: function(){ alert('Erro ao excluir.'); }
    });
});
</script>
}
