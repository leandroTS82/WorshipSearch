@model WorshipSearch.Models.SearchRestrictions
@{
    ViewData["Title"] = "Restrições de Busca";
}

<div style="max-width:720px;margin:0 auto" class="ws-fade">

    <div style="margin-bottom:28px">
        <div class="ws-page-title">Restrições de Busca</div>
        <div class="ws-page-sub">Categorias e estilos que não devem aparecer nos resultados de pesquisa do grupo de louvor.</div>
    </div>

    <div class="ws-card" style="padding:24px;margin-bottom:20px">
        <div style="font-size:12px;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);margin-bottom:16px">Adicionar Restrição</div>

        <div style="display:flex;gap:10px;align-items:center">
            <input type="text" id="new-term"
                   class="ws-input"
                   style="flex:1;padding:11px 14px"
                   placeholder="Ex: pagode, sertanejo, romântico, axé…"
                   autocomplete="off" />
            <button id="addBtn" class="ws-btn ws-btn-primary" style="padding:11px 20px;white-space:nowrap">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" style="margin-right:6px"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Adicionar
            </button>
        </div>

        <div style="margin-top:10px;font-size:12.5px;color:var(--text-dim)">
            O termo é comparado com o gênero e estilo de adoração de cada música indexada.
        </div>
    </div>

    <div class="ws-card" style="padding:24px">
        <div style="font-size:12px;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);margin-bottom:16px">
            Categorias Excluídas <span id="count-label" style="font-weight:600;color:var(--text-sub)">(@Model.Excluded.Count)</span>
        </div>

        <div id="status-msg" style="display:none;margin-bottom:14px;font-size:13.5px"></div>

        <div id="chips-area" style="display:flex;flex-wrap:wrap;gap:8px;min-height:40px">
            @if (Model.Excluded.Count == 0)
            {
                <span id="empty-msg" style="color:var(--text-dim);font-size:13.5px">Nenhuma restrição configurada.</span>
            }
            @foreach (var term in Model.Excluded)
            {
                <span class="ws-restriction-chip" data-term="@term">
                    @term
                    <button onclick="removeTerm('@term')" title="Remover">×</button>
                </span>
            }
        </div>

        <div style="margin-top:20px;padding-top:16px;border-top:1px solid var(--border-card)">
            <div style="font-size:12.5px;color:var(--text-dim);line-height:1.6">
                <strong style="color:var(--text-muted)">Exemplos de restrições comuns:</strong><br>
                pagode · sertanejo · romântico · axé · funk · rap · eletrônico · pop secular
            </div>
        </div>
    </div>

</div>

@section Scripts {
<style>
.ws-restriction-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px 6px 13px;
    border-radius: 999px;
    background: rgba(214,100,80,0.13);
    border: 1px solid rgba(214,100,80,0.32);
    color: #e89080;
    font-size: 13px;
}
.ws-restriction-chip button {
    background: none;
    border: none;
    color: #e89080;
    cursor: pointer;
    font-size: 16px;
    line-height: 1;
    padding: 0 2px;
    opacity: .7;
}
.ws-restriction-chip button:hover { opacity: 1; }
</style>
<script>
function showStatus(msg, type) {
    var colors = { ok: 'var(--accent)', err: '#ff8a80' };
    var el = $('#status-msg');
    el.css('color', colors[type] || 'var(--text-muted)').text(msg).show();
    setTimeout(function(){ el.fadeOut(); }, 2500);
}

function chipHtml(term) {
    return '<span class="ws-restriction-chip" data-term="' + escHtml(term) + '">' +
        escHtml(term) +
        '<button onclick="removeTerm(\'' + escHtml(term) + '\')" title="Remover">×</button>' +
        '</span>';
}

function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/'/g,'&#39;');
}

function updateCount(list) {
    $('#count-label').text('(' + list.length + ')');
    if (list.length === 0) {
        $('#chips-area').html('<span id="empty-msg" style="color:var(--text-dim);font-size:13.5px">Nenhuma restrição configurada.</span>');
    }
}

$('#addBtn').click(function() {
    var term = $('#new-term').val().trim();
    if (!term) return;
    $(this).prop('disabled', true);
    $.ajax({
        url: '@Url.Action("Add","SearchRestrictions")',
        method: 'POST',
        contentType: 'application/json',
        data: JSON.stringify({ term: term }),
        success: function(r) {
            if ($('[data-term="' + term + '"]').length === 0) {
                $('#empty-msg').remove();
                $('#chips-area').append(chipHtml(term));
            }
            updateCount(r.excluded);
            $('#new-term').val('');
            showStatus('Restrição adicionada.', 'ok');
        },
        error: function() { showStatus('Erro ao adicionar.', 'err'); }
    }).always(function() { $('#addBtn').prop('disabled', false); });
});

$('#new-term').on('keydown', function(e) {
    if (e.key === 'Enter') $('#addBtn').click();
});

function removeTerm(term) {
    $.ajax({
        url: '@Url.Action("Remove","SearchRestrictions")',
        method: 'POST',
        contentType: 'application/json',
        data: JSON.stringify({ term: term }),
        success: function(r) {
            $('[data-term="' + term + '"]').remove();
            updateCount(r.excluded);
            showStatus('Restrição removida.', 'ok');
        },
        error: function() { showStatus('Erro ao remover.', 'err'); }
    });
}
</script>
}
